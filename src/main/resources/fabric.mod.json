{
	"schemaVersion": 1,
	"id": "remod",
	"version": "${version}",
	"name": "ReMod",
	"description": "It can mean anything",
	"authors": [
		"jak7b",
		"Dex Moto"
	],
	"contact": {
		"homepage": "https://fabricmc.net/"
	},
	"license": "MIT",
	"icon": "assets/remod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "net.kuko.remod.ReMod",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "net.kuko.remod.ReModClient",
				"adapter": "kotlin"
			}
		],
		"fabric-datagen": [
			{
				"value": "net.kuko.remod.ReModDataGenerator",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"remod.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": ">=0.92.2+1.20.1",
		"fabric-language-kotlin": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}